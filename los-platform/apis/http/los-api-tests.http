# @name initiateESign
POST {{loanService}}/loan-agreement/esign/initiate
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "applicationId": "{{applicationId}}",
  "signerName": "Ravi Sharma",
  "signerMobile": "{{mobile}}",
  "signerEmail": "ravi.sharma@example.com"
}

> {%
