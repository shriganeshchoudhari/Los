###############################################################################
# 12. ERROR HANDLING
###############################################################################

### 401 Unauthorized
GET {{loanService}}/applications
Authorization: Bearer invalid_token_here

### 404 Not Found
GET {{loanService}}/applications/00000000-0000-0000-0000-000000000000
Authorization: Bearer {{accessToken}}

### 409 Duplicate Application
POST {{loanService}}/applications
Authorization: Bearer {{accessToken}}
Content-Type: application/json
X-Idempotency-Key: {{$guid}}

{
  "loanType": "PERSONAL_LOAN",
  "channelCode": "MOBILE_APP",
  "applicant": {
    "fullName": "Ravi Sharma",
    "dob": "1990-04-21",
    "mobile": "{{mobile}}",
    "residentialStatus": "RESIDENT_INDIAN"
  },
  "employmentDetails": {
    "employmentType": "SALARIED_PRIVATE",
    "grossMonthlyIncome": 120000,
    "netMonthlyIncome": 95000,
    "totalAnnualIncome": 1440000
  },
  "loanRequirement": {
    "loanType": "PERSONAL_LOAN",
    "requestedAmount": 500000,
    "requestedTenureMonths": 36
  }
}

### 422 Validation Error
POST {{loanService}}/applications
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "loanType": "INVALID_TYPE",
  "channelCode": "MOBILE_APP",
  "applicant": {
    "fullName": "A",
    "dob": "invalid-date",
    "mobile": "123",
    "residentialStatus": "RESIDENT_INDIAN"
  },
  "employmentDetails": {
    "employmentType": "SALARIED_PRIVATE",
    "grossMonthlyIncome": -1000,
    "netMonthlyIncome": -500,
    "totalAnnualIncome": -600
  },
  "loanRequirement": {
    "loanType": "PERSONAL_LOAN",
    "requestedAmount": 0,
    "requestedTenureMonths": 0
  }
}
