# ── Database ──────────────────────────────────────────────────────────────────
DB_PASSWORD=los_password

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=dev_jwt_secret_minimum_32_characters_change_in_production
JWT_EXPIRY=15m

# ── DSA ────────────────────────────────────────────────────────────────────────
DSA_JWT_SECRET=dev_dsa_jwt_secret_minimum_32_characters_change_in_production
ENCRYPTION_KEY=dev_encryption_key_32_characters

# ── LDAP ─────────────────────────────────────────────────────────────────────
LDAP_URL=ldap://localhost:389
LDAP_BASE_DN=dc=bank,dc=internal

# ── SMS / Email ───────────────────────────────────────────────────────────────
SMS_API_KEY=your_sms_provider_api_key
SMS_SENDER_ID=LOSBNK
EMAIL_API_KEY=your_email_provider_api_key
EMAIL_FROM=noreply@losbank.in
WHATSAPP_API_KEY=your_whatsapp_api_key

# ── Push Notifications ────────────────────────────────────────────────────────
FCM_SERVER_KEY=your_fcm_server_key

# ── UIDAI (Aadhaar) ─────────────────────────────────────────────────────────
UIDAI_LICENSE_KEY=your_uidai_license_key

# ── DigiLocker ──────────────────────────────────────────────────────────────
DIGILOCKER_CLIENT_ID=your_digilocker_client_id
DIGILOCKER_CLIENT_SECRET=your_digilocker_client_secret

# ── Credit Bureaus ──────────────────────────────────────────────────────────
BUREAU_CIBIL_API_KEY=your_cibil_api_key
BUREAU_EXPERIAN_API_KEY=your_experian_api_key
BUREAU_EQUIFAX_API_KEY=your_equifax_api_key
BUREAU_CRIF_API_KEY=your_crif_api_key

# ── CBS (Core Banking — Finacle) ───────────────────────────────────────────
CBS_BASE_URL=https://finacle.bank.internal:8080
CBS_USERNAME=your_cbs_username
CBS_PASSWORD=your_cbs_password

# ── NPCI Payments ───────────────────────────────────────────────────────────
NPCI_BASE_URL=https://npci.bank.internal
NPCI_MERCHANT_ID=your_merchant_id
NPCI_API_KEY=your_npci_api_key

# ── Document Processing ──────────────────────────────────────────────────────
KARZA_API_KEY=your_karza_api_key
SIGNZY_API_KEY=your_signzy_api_key

# ── OpenTelemetry ───────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_TRACES_SAMPLER=parentbased_always_on
OTEL_PROPAGATORS=b3,tracecontext
