# LOS Platform Backend — Environment Variables Template
# Copy this to .env and fill in the values

# ─── Application ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_NAME=LOS-Platform

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=los_auth
DB_USER=los_user
DB_PASSWORD=changeme
DB_SYNC=false

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── Kafka ───────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=los-platform
KAFKA_GROUP_ID_PREFIX=los-platform
KAFKA_RETRY_ATTEMPTS=3
KAFKA_RETRY_DELAY_MS=1000

# ─── JWT / Auth (RS256) ─────────────────────────────────────────────────────────
# ⚠️  CRITICAL: JWT_PRIVATE_KEY must be PERSISTENT across restarts.
#    Ephemeral keys invalidate all active sessions and break multi-instance deployments.
#
# Generate RSA-2048 key pair:
#   bash scripts/gen-jwt-keys.sh
#   # or on Windows: .\scripts\gen-jwt-keys.ps1
#   # Keys written to: backend/keys/jwt-private.pem, backend/keys/jwt-public.pem
#
# ⚠️ NEVER commit .pem files. They are excluded in .gitignore.
#
# Local Docker: use JWT_PRIVATE_KEY_FILE (mounted via docker-compose volume)
#   JWT_PRIVATE_KEY_FILE=/keys/jwt-private.pem
#
# Development: paste key content directly (never for production)
# Production:   load from HashiCorp Vault via VAULT_TOKEN or AWS IAM role
#   vault kv get secret/los-platform/jwt/private
#   vault kv get secret/los-platform/jwt/public
#
# Key Rotation (quarterly):
#   1. Generate new key pair
#   2. Add new public key to JWKS endpoint (support both old + new during transition)
#   3. Deploy auth-service with new private key
#   4. After grace period (15 min), revoke old key
JWT_PRIVATE_KEY_FILE=/keys/jwt-private.pem
JWT_PUBLIC_KEY=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# OTP
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_MAX_PER_HOUR=3

# LDAP
LDAP_URL=ldap://ldap.example.com:389
LDAP_BIND_DN=cn=admin,dc=example,dc=com
LDAP_BIND_PASSWORD=
LDAP_SEARCH_BASE=ou=users,dc=example,dc=com
LDAP_SEARCH_FILTER=(uid={{username}})

# ─── External APIs ─────────────────────────────────────────────────────────────

# UIDAI Aadhaar (apply at https://uidai.gov.in)
UIDAI_AUA_CODE=
UIDAI_LICENSE_KEY=
UIDAI_ASA_LICENSE_KEY=
UIDAI_STAGING_URL=https://stage1.uidai.gov.in
UIDAI_PRODUCTION_URL=https://auth.uidai.gov.in
UIDAI_RSA_PRIVATE_KEY_PATH=./keys/uidai-private.pem
UIDAI_RSA_PUBLIC_KEY_PATH=./keys/uidai-public.pem

# NSDL PAN Verification
NSDL_API_URL=https://www.tin-nsdl.com/services/tinwebservices.asmx
NSDL_SECRET_KEY=
NSDL_USER_ID=
NSDL_TAN=

# Bureau APIs
CIBIL_API_URL=https://api.cibil.com
CIBIL_API_KEY=
CIBIL_MEMBER_ID=
EXPERIAN_API_URL=https://api.experian.com
EXPERIAN_API_KEY=
EQUIFAX_API_URL=https://ws.equifax.com
EQUIFAX_API_KEY=
CRIF_API_URL=https://api.crifhighmark.com
CRIF_API_KEY=

# NPCI (NACH + IMPS/NEFT/RTGS)
NPCI_API_URL=https://npcips-prod.npci.org.in
NPCI_SP_KEY=
NPCI_SP_CODE=
NPCI_MERCHANT_ID=

# NSDL eSign
ESIGN_PROVIDER=NSDL_ESIGN
ESIGN_API_URL=https://esignuat.safescrypt.in/api/v1
ESIGN_ACCESS_CODE=
ESIGN_PDF_SIGNER_CERT_PATH=./keys/esign-cert.pem
ESIGN_PDF_SIGNER_KEY_PATH=./keys/esign-key.pem
ESIGN_RETURN_URL=https://los.example.com/application/esign/return

# SMS (Kaleyra)
KALEYRA_API_KEY=
KALEYRA_SENDER_ID=LOSBNK
KALEYRA_TEMPLATE_ID=
KALEYRA_URL=https://api.kaleyra.io/v1/

# WhatsApp (Gupshup)
GUPSHUP_API_KEY=
GUPSHUP_TEMPLATE_ID=
GUPSHUP_URL=https://api.gupshup.io

# Document OCR (Karza/Signzy)
KARZA_API_KEY=
KARZA_OCR_URL=https://api.karza.in/v2/ocr
SIGNZY_API_KEY=
SIGNZY_OCR_URL=https://api.signzy.tech

# ─── MinIO / S3 ─────────────────────────────────────────────────────────────
S3_ENDPOINT=localhost:9000
S3_ACCESS_KEY=losminio
S3_SECRET_KEY=changeminio
S3_BUCKET=los-documents
S3_REGION=ap-south-1
S3_USE_SSL=false

# ─── Notification Templates ───────────────────────────────────────────────────
NOTIFICATION_FROM_EMAIL=noreply@losbank.example.com
NOTIFICATION_FROM_SMS=LOSBNK

# ─── Vault (production) ──────────────────────────────────────────────────────
VAULT_ADDR=https://vault.example.com
VAULT_TOKEN=
VAULT_KV_PATH=secret/los-platform

# ─── Observability ───────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=los-platform
OTEL_TRACES_SAMPLER_ARG=0.1

# ─── Feature Flags ───────────────────────────────────────────────────────────
ENABLE_MOCK_EXTERNAL_APIS=true
ENABLE_BUREAU_MOCK=true
ENABLE_UIDAI_MOCK=true
ENABLE_NSDL_MOCK=true
ENABLE_ESIGN_MOCK=true

# ─── Rates (loan pricing) ───────────────────────────────────────────────────
BENCHMARK_RATE_TYPE=MCLR_3M
DEFAULT_PROCESSING_FEE_PCT=2.0
MIN_PROCESSING_FEE_AMOUNT=1000
