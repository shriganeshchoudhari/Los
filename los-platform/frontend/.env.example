# LOS Platform Frontend — Environment Variables Template
# Copy this to .env.local and fill in values for local development

# ─── API Gateway (Production) ───────────────────────────────────────────────────
# In production, route all traffic through Kong API Gateway
NEXT_PUBLIC_API_GATEWAY_URL=https://api.los-bank.internal

# ─── Per-Service URLs (Local Dev — direct service calls) ──────────────────────
# Use these for local development without Kong. Each service runs on its own port.
NEXT_PUBLIC_AUTH_SERVICE_URL=http://localhost:3001
NEXT_PUBLIC_KYC_SERVICE_URL=http://localhost:3002
NEXT_PUBLIC_LOAN_SERVICE_URL=http://localhost:3003
NEXT_PUBLIC_DOCUMENT_SERVICE_URL=http://localhost:3009
NEXT_PUBLIC_DECISION_SERVICE_URL=http://localhost:3005
NEXT_PUBLIC_INTEGRATION_SERVICE_URL=http://localhost:3006
NEXT_PUBLIC_NOTIFICATION_SERVICE_URL=http://localhost:3007
NEXT_PUBLIC_DSA_SERVICE_URL=http://localhost:3008

# ─── Legacy / Fallback (unused when per-service URLs are set) ─────────────────
# Kept for backward compatibility — do not use in new setups
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ENV=development
